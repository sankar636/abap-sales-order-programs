CALL FUNCTION 'ZFM_SALES_ORDER'
  EXPORTING
    serdat      = s_erdat[]
    sernam      = s_ernam[]
  IMPORTING
    lt_output   = lt_final
  EXCEPTIONS
    wrong_input = 1
    OTHERS      = 2.
IF sy-subrc <> 0.
* Implement suitable error handling here
  MESSAGE i000(zmsg_sales).
ELSE.
  lwa_fieldcat-col_pos = '1'.
  lwa_fieldcat-fieldname = 'VBELN'.
  lwa_fieldcat-seltext_l = TEXT-001.
  APPEND lwa_fieldcat TO lt_fieldcat.
  CLEAR lwa_fieldcat.

  lwa_fieldcat-col_pos = '2'.
  lwa_fieldcat-fieldname = 'POSNR'.
  lwa_fieldcat-seltext_l = TEXT-002.
  APPEND lwa_fieldcat TO lt_fieldcat.
  CLEAR lwa_fieldcat.

  lwa_fieldcat-col_pos = '3'.
  lwa_fieldcat-fieldname = 'MATNR'.
  lwa_fieldcat-seltext_l = TEXT-003.
  APPEND lwa_fieldcat TO lt_fieldcat.
  CLEAR lwa_fieldcat.

  lwa_fieldcat-col_pos = '4'.
  lwa_fieldcat-fieldname = 'MAKTX'.
  lwa_fieldcat-seltext_l = TEXT-004.
  APPEND lwa_fieldcat TO lt_fieldcat.
  CLEAR lwa_fieldcat.

  lwa_fieldcat-col_pos = '5'.
  lwa_fieldcat-fieldname = 'KWMENG'.
  lwa_fieldcat-seltext_l = TEXT-005.
  APPEND lwa_fieldcat TO lt_fieldcat.
  CLEAR lwa_fieldcat.

  lwa_fieldcat-col_pos = '6'.
  lwa_fieldcat-fieldname = 'VRKME'.
  lwa_fieldcat-seltext_l = TEXT-006.
  APPEND lwa_fieldcat TO lt_fieldcat.
  CLEAR lwa_fieldcat.

